{
  "name": "GCP Memcache Node",
  "description": null,
  "pages": [
    {
      "name": "GCP Memcache Node",
      "description": null,
      "widgets": [
        {
          "title": "Active Connections",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT average(`gcp.memcache.node.active_connections`) AS 'Connections' FROM Metric WHERE entity.guid = '{{entity.id}}' TIMESERIES auto"
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "title": "Hit Ratio (%)",
          "layout": {
            "column": 5,
            "row": 1,
