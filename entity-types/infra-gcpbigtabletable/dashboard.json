      "widgets": [
        {
          "title": "Server requests",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT sum(`gcp.bigtable.server.request_count`) AS 'Requests' FROM Metric WHERE entity.guid IN ({{entity.id}}) TIMESERIES AUTO"
              }
            ]
          }
        },
