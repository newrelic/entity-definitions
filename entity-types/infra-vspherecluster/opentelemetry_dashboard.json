{
  "name": "vSphere Cluster (OpenTelemetry)",
  "pages": [
    {
      "name": "Overview",
      "description": null,
      "widgets": [
        {
          "visualization": {
            "id": "viz.billboard"
          },
          "layout": {
            "column": 1,
            "row": 1,
            "height": 3,
            "width": 3
          },
          "title": "Host count",
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "query": "FROM Metric SELECT latest(vcenter.cluster.host.count) WHERE instrumentation.provider = 'opentelemetry' FACET vcenter.cluster.name",
                "accountId": 0}
            ]
          }
        },
        {
          "visualization": {
            "id": "viz.billboard"
          },
          "layout": {
            "column": 4,
            "row": 1,
            "height": 3,
            "width": 3
          },
          "title": "VM count",
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "query": "FROM Metric SELECT latest(vcenter.cluster.vm.count) WHERE instrumentation.provider = 'opentelemetry' FACET vcenter.cluster.name",
                "accountId": 0}
            ]
          }
        },
        {
          "visualization": {
            "id": "viz.billboard"
          },
          "layout": {
            "column": 7,
            "row": 1,
            "height": 3,
            "width": 3
