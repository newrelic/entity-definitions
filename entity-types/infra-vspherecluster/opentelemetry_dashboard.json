            "nrqlQueries": [
              {
                "query": "FROM Metric SELECT latest(vcenter.cluster.cpu.effective) WHERE instrumentation.provider = 'opentelemetry' FACET vcenter.cluster.name TIMESERIES AUTO",
                "accountId": 0}
            ]
          }
