          "title": "Memory effective (GiB)",
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "query": "FROM Metric SELECT latest(vcenter.cluster.memory.effective) / 1e9 WHERE instrumentation.provider = 'opentelemetry' FACET vcenter.cluster.name TIMESERIES AUTO",
                "accountId": 0}
            ],
            "units": {
              "unit": "BYTES"
            }
