          "rawConfiguration": {
            "nrqlQueries": [
              {
                "query": "FROM Metric SELECT average(vcenter.cluster.vsan.throughput) WHERE instrumentation.provider = 'opentelemetry' FACET vcenter.cluster.name, direction TIMESERIES AUTO",
                "accountId": 0}
            ],
            "units": {
              "unit": "BYTES_PER_SECOND"
            }
          }
        },
