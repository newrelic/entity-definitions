{
  "name": "GCP Firebase Hosting Domain",
  "description": null,
  "pages": [
    {
      "name": "GCP Firebase Hosting Domain",
      "description": null,
      "widgets": [
        {
          "title": "Sent Bytes",
          "layout": {"column": 1, "row": 1, "width": 4, "height": 3},
          "visualization": {"id": "viz.line"},
          "rawConfiguration": {
            "facet": {"showOtherSeries": false},
            "legend": {"enabled": true},
            "nrqlQueries": [{"accountId": 0, "query": "FROM Metric SELECT sum(`gcp.firebasehosting.network.sent_bytes_count`) AS 'Sent Bytes' WHERE `entity.guid` = '{{entity.guid}}' TIMESERIES AUTO"}],
            "yAxisLeft": {"zero": true}
          }
        },
        {
          "title": "Monthly Sent vs Limit (bytes)",
          "layout": {"column": 5, "row": 1, "width": 4, "height": 3},
          "visualization": {"id": "viz.line"},
          "rawConfiguration": {
            "facet": {"showOtherSeries": false},
            "legend": {"enabled": true},
            "nrqlQueries": [{"accountId": 0, "query": "FROM Metric SELECT average(`gcp.firebasehosting.network.monthly_sent`) AS 'Monthly Sent', average(`gcp.firebasehosting.network.monthly_sent_limit`) AS 'Monthly Limit' WHERE `entity.guid` = '{{entity.guid}}' TIMESERIES AUTO"}],
            "yAxisLeft": {"zero": true}
          }
        },
        {
          "title": "Storage (bytes)",
          "layout": {"column": 9, "row": 1, "width": 4, "height": 3},
          "visualization": {"id": "viz.line"},
          "rawConfiguration": {
            "facet": {"showOtherSeries": false},
            "legend": {"enabled": true},
            "nrqlQueries": [{"accountId": 0, "query": "FROM Metric SELECT average(`gcp.firebasehosting.storage.total_bytes`) AS 'Storage Used', average(`gcp.firebasehosting.storage.limit`) AS 'Storage Limit' WHERE `entity.guid` = '{{entity.guid}}' TIMESERIES AUTO"}],
            "yAxisLeft": {"zero": true}
          }
        }
      ]
    }
  ]
}
