              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "FROM Metric SELECT latest(haproxy.sessions.average) AS 'Avg Session Time (ms)' WHERE haproxy.service_name = 'BACKEND' FACET haproxy.proxy_name TIMESERIES"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "title": "Errors",
          "layout": {
            "column": 1,
            "row": 10,
            "width": 2,
            "height": 6
          },
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
