                "accountId": 0,
                "query": "FROM Metric SELECT rate(sum(haproxy.server_selected.total), 1 second) AS 'Selections/sec', rate(sum(haproxy.connections.retries), 1 minute) AS 'Retries/min', rate(sum(haproxy.requests.redispatched), 1 minute) AS 'Redispatches/min', rate(sum(haproxy.requests.queued), 1 minute) AS 'Queued/min' WHERE haproxy.service_name NOT IN ('FRONTEND', 'BACKEND') FACET haproxy.proxy_name, haproxy.service_name"
