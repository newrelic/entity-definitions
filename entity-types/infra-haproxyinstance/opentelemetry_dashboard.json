            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "FROM Metric SELECT latest(haproxy.connections.rate) AS 'Connections/sec' WHERE haproxy.service_name = 'FRONTEND' FACET haproxy.proxy_name TIMESERIES"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            },
