        {
          "title": "Active Sessions",
          "layout": {
            "column": 8,
            "row": 4,
            "width": 5,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "FROM Metric SELECT latest(haproxy.sessions.count) AS 'Active Sessions' FACET haproxy.proxy_name, haproxy.service_name TIMESERIES"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "title": "Network I/O (Bytes/sec)",
          "layout": {
            "column": 3,
            "row": 7,
            "width": 5,
            "height": 3
          },
          "visualization": {
            "id": "viz.area"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "FROM Metric SELECT rate(sum(haproxy.bytes.input), 1 second) AS 'Bytes In/sec', rate(sum(haproxy.bytes.output), 1 second) AS 'Bytes Out/sec' WHERE haproxy.service_name = 'FRONTEND' TIMESERIES"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
          }
        },
        {
