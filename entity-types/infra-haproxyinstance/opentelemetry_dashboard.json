{
  "name": "HAProxy Instance",
  "pages": [
    {
      "name": "Overview",
      "description": null,
      "widgets": [
        {
          "title": "",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 2,
            "height": 9
          },
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "FROM Metric SELECT latest(haproxy.sessions.rate) AS 'Sessions/sec', latest(haproxy.requests.rate) AS 'Requests/sec', latest(haproxy.connections.rate) AS 'Connections/sec', latest(haproxy.sessions.count) AS 'Active Sessions', rate(sum(haproxy.connections.errors), 1 minute) AS 'Connection Errors/min', rate(sum(haproxy.responses.errors), 1 minute) AS 'Response Errors/min' WHERE haproxy.service_name IN ('FRONTEND', 'BACKEND') compare with 1 hour ago"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            }
          }
        },
        {
          "title": "Sessions per second",
          "layout": {
            "column": 3,
            "row": 1,
            "width": 5,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "FROM Metric SELECT latest(haproxy.sessions.rate) AS 'Sessions/sec' FACET haproxy.proxy_name TIMESERIES"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "title": "Requests per second (Frontend)",
          "layout": {
            "column": 8,
            "row": 1,
            "width": 5,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "FROM Metric SELECT latest(haproxy.requests.rate) AS 'Requests/sec' WHERE haproxy.service_name = 'FRONTEND' FACET haproxy.proxy_name TIMESERIES"
              }
            ],
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "title": "Connections per second (Frontend)",
          "layout": {
            "column": 3,
