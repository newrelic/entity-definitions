            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "FROM Metric SELECT average(`gcp.alloydb.database.conn_pool.client_connection_wait_time`) AS 'Wait Time (ms)' WHERE entity.guid = '{{entity.guid}}' TIMESERIES AUTO FACET `metric.pooler`"
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        },
