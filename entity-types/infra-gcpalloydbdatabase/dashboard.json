{
  "name": "GCP AlloyDB Database",
  "description": null,
  "pages": [
    {
      "name": "GCP AlloyDB Database",
      "description": null,
      "widgets": [
        {
          "title": "Client Connections",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "FROM Metric SELECT sum(`gcp.alloydb.database.conn_pool.client_connections`) AS 'Client Connections' WHERE entity.guid = '{{entity.guid}}' TIMESERIES AUTO FACET `metric.status`, `metric.pooler`"
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "title": "Server Connections",
          "layout": {
            "column": 5,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
