{
  "name": "AI Tool Dashboard",
  "description": "Overview dashboard for AI Tool",
  "pages": [
    {
      "name": "AI Tool dashboard",
      "description": "",
      "widgets": [
        {
          "title": "Latency (Average execution time)",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT average(duration.ms) AS 'Latency (ms)' FROM Span WHERE subcomponent.entity.guid = '{{entity.id}}' TIMESERIES"
              }
            ]
          }
        },
        {
          "title": "Throughput (invocations per minute)",
          "layout": {
            "column": 5,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT rate(count(*), 1 minute) AS 'Throughput' FROM Span WHERE subcomponent.entity.guid = '{{entity.id}}' TIMESERIES"
              }
            ]
          }
        },
        {
          "title": "Error Rate (% of failed executions)",
          "layout": {
            "column": 9,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT percentage(count(*), WHERE otel.status_code = 'ERROR') AS 'Error %' FROM Span WHERE subcomponent.entity.guid = '{{entity.id}}' TIMESERIES"
              }
            ]
          }
        }
      ]
    }
  ]
}
