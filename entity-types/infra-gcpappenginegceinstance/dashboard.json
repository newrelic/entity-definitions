{
  "name": "GCP App Engine Flex VM",
  "description": null,
  "pages": [
    {
      "name": "GCP App Engine Flex VM",
      "description": null,
      "widgets": [
        {
          "title": "Connections (current)",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT max(`gcp.appengine.flex.autoscaler.connections.current`) AS 'Connections' FROM Metric WHERE entity.guid = '{{entity.id}}' TIMESERIES AUTO",
                "offset": 300000
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "title": "Request count",
          "layout": {
            "column": 5,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT sum(`gcp.appengine.flex.autoscaler.server.request_count`) AS 'Requests' FROM Metric WHERE entity.guid = '{{entity.id}}' TIMESERIES AUTO",
                "offset": 300000
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "title": "Connections by state",
          "layout": {
