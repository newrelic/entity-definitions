            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT max(`gcp.appengine.flex.autoscaler.connections.current`) AS 'Connections' FROM Metric WHERE entity.guid = '{{entity.id}}' FACET `metric.state` TIMESERIES AUTO",
                "offset": 300000
              }
            ],
            "yAxisLeft": {
              "zero": true
