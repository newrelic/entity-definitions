              {
                "query": "SELECT latest(flink.job.checkpoint.in_progress) FROM Metric WHERE instrumentation.provider = 'opentelemetry' FACET flink.job.name TIMESERIES AUTO",
                "accountId": 0
              }
            ]
          }
        },
        {
          "visualization": { "id": "viz.line" },
          "layout": { "column": 7, "row": 4, "height": 3, "width": 6 },
          "title": "Last Checkpoint Size (bytes)",
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "query": "SELECT latest(flink.job.last_checkpoint.size) FROM Metric WHERE instrumentation.provider = 'opentelemetry' FACET flink.job.name TIMESERIES AUTO",
                "accountId": 0
