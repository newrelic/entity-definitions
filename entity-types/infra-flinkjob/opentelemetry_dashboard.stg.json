            "nrqlQueries": [
              {
                "query": "SELECT latest(flink.job.last_checkpoint.time) FROM Metric WHERE instrumentation.provider = 'opentelemetry' FACET flink.job.name TIMESERIES AUTO",
                "accountId": 0
              }
            ]
          }
        },
        {
          "visualization": { "id": "viz.line" },
