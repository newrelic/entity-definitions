{
  "name": "GCP Firebase Database Namespace",
  "description": null,
  "pages": [
    {
      "name": "GCP Firebase Database Namespace",
      "description": null,
      "widgets": [
        {
          "title": "I/O Utilization",
          "layout": {"column": 1, "row": 1, "width": 4, "height": 3},
          "visualization": {"id": "viz.line"},
          "rawConfiguration": {
            "facet": {"showOtherSeries": false},
            "legend": {"enabled": true},
            "nrqlQueries": [{"accountId": 0, "query": "FROM Metric SELECT average(`gcp.firebasedatabase.io.utilization`) * 100 AS 'I/O Utilization %' WHERE `entity.guid` = '{{entity.guid}}' TIMESERIES AUTO"}],
            "yAxisLeft": {"zero": true}
          }
        },
        {
          "title": "Active Connections",
          "layout": {"column": 5, "row": 1, "width": 4, "height": 3},
          "visualization": {"id": "viz.line"},
          "rawConfiguration": {
            "facet": {"showOtherSeries": false},
            "legend": {"enabled": true},
            "nrqlQueries": [{"accountId": 0, "query": "FROM Metric SELECT average(`gcp.firebasedatabase.network.active_connections`) AS 'Active Connections' WHERE `entity.guid` = '{{entity.guid}}' TIMESERIES AUTO"}],
            "yAxisLeft": {"zero": true}
          }
        },
        {
          "title": "Sent Bytes",
          "layout": {"column": 9, "row": 1, "width": 4, "height": 3},
          "visualization": {"id": "viz.line"},
          "rawConfiguration": {
            "facet": {"showOtherSeries": false},
            "legend": {"enabled": true},
            "nrqlQueries": [{"accountId": 0, "query": "FROM Metric SELECT sum(`gcp.firebasedatabase.network.sent_bytes_count`) AS 'Sent Bytes' WHERE `entity.guid` = '{{entity.guid}}' TIMESERIES AUTO"}],
            "yAxisLeft": {"zero": true}
          }
        },
        {
          "title": "Database Load by Type",
          "layout": {"column": 1, "row": 4, "width": 4, "height": 3},
          "visualization": {"id": "viz.line"},
          "rawConfiguration": {
            "facet": {"showOtherSeries": false},
            "legend": {"enabled": true},
            "nrqlQueries": [{"accountId": 0, "query": "FROM Metric SELECT average(`gcp.firebasedatabase.io.database_load`) AS 'DB Load' WHERE `entity.guid` = '{{entity.guid}}' FACET `metric.type` TIMESERIES AUTO"}],
            "yAxisLeft": {"zero": true}
          }
        },
        {
          "title": "API Hits by Operation Type",
          "layout": {"column": 5, "row": 4, "width": 4, "height": 3},
          "visualization": {"id": "viz.line"},
          "rawConfiguration": {
            "facet": {"showOtherSeries": false},
            "legend": {"enabled": true},
            "nrqlQueries": [{"accountId": 0, "query": "FROM Metric SELECT sum(`gcp.firebasedatabase.network.api_hits_count`) AS 'API Hits' WHERE `entity.guid` = '{{entity.guid}}' FACET `metric.operation_type` TIMESERIES AUTO"}],
            "yAxisLeft": {"zero": true}
          }
        },
        {
          "title": "HTTPS Requests",
          "layout": {"column": 9, "row": 4, "width": 4, "height": 3},
          "visualization": {"id": "viz.line"},
          "rawConfiguration": {
            "facet": {"showOtherSeries": false},
            "legend": {"enabled": true},
            "nrqlQueries": [{"accountId": 0, "query": "FROM Metric SELECT sum(`gcp.firebasedatabase.network.https_requests_count`) AS 'HTTPS Requests' WHERE `entity.guid` = '{{entity.guid}}' TIMESERIES AUTO"}],
            "yAxisLeft": {"zero": true}
          }
        },
        {
          "title": "Monthly Sent vs Limit (bytes)",
          "layout": {"column": 1, "row": 7, "width": 4, "height": 3},
          "visualization": {"id": "viz.line"},
          "rawConfiguration": {
            "facet": {"showOtherSeries": false},
            "legend": {"enabled": true},
            "nrqlQueries": [{"accountId": 0, "query": "FROM Metric SELECT average(`gcp.firebasedatabase.network.monthly_sent`) AS 'Monthly Sent', average(`gcp.firebasedatabase.network.monthly_sent_limit`) AS 'Monthly Limit' WHERE `entity.guid` = '{{entity.guid}}' TIMESERIES AUTO"}],
            "yAxisLeft": {"zero": true}
          }
        },
        {
          "title": "Storage (bytes)",
          "layout": {"column": 5, "row": 7, "width": 4, "height": 3},
          "visualization": {"id": "viz.line"},
          "rawConfiguration": {
            "facet": {"showOtherSeries": false},
            "legend": {"enabled": true},
            "nrqlQueries": [{"accountId": 0, "query": "FROM Metric SELECT average(`gcp.firebasedatabase.storage.total_bytes`) AS 'Storage Used', average(`gcp.firebasedatabase.storage.limit`) AS 'Storage Limit' WHERE `entity.guid` = '{{entity.guid}}' TIMESERIES AUTO"}],
            "yAxisLeft": {"zero": true}
          }
        },
        {
          "title": "Broadcast Load",
          "layout": {"column": 9, "row": 7, "width": 4, "height": 3},
          "visualization": {"id": "viz.line"},
          "rawConfiguration": {
            "facet": {"showOtherSeries": false},
            "legend": {"enabled": true},
            "nrqlQueries": [{"accountId": 0, "query": "FROM Metric SELECT average(`gcp.firebasedatabase.network.broadcast_load`) AS 'Broadcast Load' WHERE `entity.guid` = '{{entity.guid}}' TIMESERIES AUTO"}],
            "yAxisLeft": {"zero": true}
          }
        }
      ]
    }
  ]
}
