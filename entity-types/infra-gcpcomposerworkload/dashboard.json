{
  "name": "GCP Cloud Composer Workload",
  "description": null,
  "pages": [
    {
      "name": "Summary",
      "description": null,
      "widgets": [
        {
          "title": "CPU Usage Time",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT sum(`gcp.composer.workload.cpu.usage_time`) FROM Metric WHERE entity.guid = '{{entity.id}}' TIMESERIES auto"
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "title": "CPU Reserved Cores",
          "layout": {
            "column": 5,
            "row": 1,
            "width": 4,
            "height": 3
