{
  "name": "GCP HTTP(S) External Regional Load Balancer",
  "description": null,
  "pages": [
    {
      "name": "GCP HTTP(S) External Regional Load Balancer",
      "description": null,
      "widgets": [
        {
          "title": "Backend Requests/s",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "FROM Metric SELECT rate(sum(`gcp.loadbalancing.https.external.regional.backend_request_count`), 1 minute) / 60 AS 'Backend RPS' WHERE `entity.guid` = '{{entity.guid}}' TIMESERIES AUTO"
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "title": "Total Requests/s",
          "layout": {
            "column": 5,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "FROM Metric SELECT rate(sum(`gcp.loadbalancing.https.external.regional.request_count`), 1 minute) / 60 AS 'Total RPS' WHERE `entity.guid` = '{{entity.guid}}' TIMESERIES AUTO"
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "title": "Backend Latency (ms)",
          "layout": {
            "column": 9,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "FROM Metric SELECT max(`gcp.loadbalancing.https.external.regional.backend_latencies`) AS 'Backend Latency (ms)' WHERE `entity.guid` = '{{entity.guid}}' TIMESERIES AUTO"
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "title": "Total Latency (ms)",
          "layout": {
            "column": 1,
            "row": 4,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "FROM Metric SELECT max(`gcp.loadbalancing.https.external.regional.total_latencies`) AS 'Total Latency (ms)' WHERE `entity.guid` = '{{entity.guid}}' TIMESERIES AUTO"
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        }
      ]
    }
  ]
}