            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT rate(sum(`gcp.alloydb.instance.postgres.abort_count`), 1 minute) AS 'Rollbacks/min' FROM Metric WHERE entity.guid = '{{entity.id}}' TIMESERIES auto"
              }
