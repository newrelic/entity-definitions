{
  "name": "GCP Cloud Composer Environment",
  "description": null,
  "pages": [
    {
      "name": "Summary",
      "description": null,
      "widgets": [
        {
          "title": "Running Tasks",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT average(`gcp.composer.environment.executor.running_tasks`) FROM Metric WHERE entity.guid = '{{entity.id}}' TIMESERIES auto"
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
