            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT sum(`gcp.router.bfd.control.received_packets_count`) AS 'Received', sum(`gcp.router.bfd.control.transmitted_packets_count`) AS 'Transmitted' FROM Metric WHERE entity.guid = '{{entity.id}}' TIMESERIES auto"
