          "title": "VM count by power state",
          "rawConfiguration": {
            "nrqlQueries": [
              {
                "query": "FROM Metric SELECT latest(vcenter.datacenter.vm.count) WHERE instrumentation.provider = 'opentelemetry' FACET power_state TIMESERIES AUTO",
                "accountId": 0}
            ]
          }
        }
      ]
    }
