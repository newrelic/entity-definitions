{
  "name": "GCP Pub/Sub Snapshot",
  "description": null,
  "pages": [
    {
      "name": "Summary",
      "description": null,
      "widgets": [
        {
          "title": "Backlog Bytes",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "SELECT sum(`gcp.pubsub.snapshot.backlog_bytes`) FROM Metric WHERE entity.guid = '{{entity.id}}' TIMESERIES auto"
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
