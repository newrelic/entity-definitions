          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "FROM Metric SELECT sum(`gcp.bigquery.storage.uploaded_bytes`) AS 'Uploaded Bytes' WHERE entity.guid IN ({{entity.guid}}) TIMESERIES AUTO"
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "title": "Uploaded Bytes Billed",
          "layout": {
            "column": 5,
