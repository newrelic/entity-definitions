            "width": 4,
            "height": 3
          },
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "legend": {
              "enabled": true
            },
            "nrqlQueries": [
              {
                "accountId": 0,
                "query": "FROM Metric SELECT sum(`gcp.bigquery.storage.uploaded_bytes_billed`) AS 'Uploaded Bytes Billed' WHERE entity.guid IN ({{entity.guid}}) TIMESERIES AUTO"
              }
            ],
            "yAxisLeft": {
              "zero": true
            }
          }
        },
        {
          "title": "Uploaded Rows",
