              {
                "accountIds": [
                  4314894
                ],
                "query": "WITH duration / 1000 AS jobDuration\nFROM SparkJob\nSELECT sparkAppName AS Application, jobId AS 'Job ID', description, status, submissionTime, completionTime, completedStageCount AS 'Completed Stages', failedStageCount AS 'Failed Stages', skippedStageCount AS 'Skipped Stages', taskCount\nWHERE event = 'complete'\nORDER BY jobDuration DESC\nLIMIT MAX"
              }
            ],
