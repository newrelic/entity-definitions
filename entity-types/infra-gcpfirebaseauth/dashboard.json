{
  "name": "GCP Firebase Auth",
  "description": null,
  "pages": [
    {
      "name": "GCP Firebase Auth",
      "description": null,
      "widgets": [
        {
          "title": "Phone Verification Count",
          "layout": {"column": 1, "row": 1, "width": 4, "height": 3},
          "visualization": {"id": "viz.line"},
          "rawConfiguration": {
            "facet": {"showOtherSeries": false},
            "legend": {"enabled": true},
            "nrqlQueries": [{"accountId": 0, "query": "FROM Metric SELECT sum(`gcp.firebaseauth.phone_auth.phone_verification_count`) AS 'Verifications' WHERE `entity.guid` = '{{entity.guid}}' TIMESERIES AUTO"}],
            "yAxisLeft": {"zero": true}
          }
        },
        {
          "title": "Phone Verifications by Country",
          "layout": {"column": 5, "row": 1, "width": 4, "height": 3},
          "visualization": {"id": "viz.line"},
          "rawConfiguration": {
            "facet": {"showOtherSeries": false},
            "legend": {"enabled": true},
            "nrqlQueries": [{"accountId": 0, "query": "FROM Metric SELECT sum(`gcp.firebaseauth.phone_auth.phone_verification_count`) AS 'Verifications' WHERE `entity.guid` = '{{entity.guid}}' FACET `metric.country_code` TIMESERIES AUTO"}],
            "yAxisLeft": {"zero": true}
          }
        },
        {
          "title": "Phone Verifications by Tier",
          "layout": {"column": 9, "row": 1, "width": 4, "height": 3},
          "visualization": {"id": "viz.line"},
          "rawConfiguration": {
            "facet": {"showOtherSeries": false},
            "legend": {"enabled": true},
            "nrqlQueries": [{"accountId": 0, "query": "FROM Metric SELECT sum(`gcp.firebaseauth.phone_auth.phone_verification_count`) AS 'Verifications' WHERE `entity.guid` = '{{entity.guid}}' FACET `metric.tier_name` TIMESERIES AUTO"}],
            "yAxisLeft": {"zero": true}
          }
        }
      ]
    }
  ]
}
